# ARK Landing Page Environment Variables

# Production URL Configuration - Choose ONE strategy:

# Option 1: Single dashboard URL with namespace parameter
# NEXT_PUBLIC_ARK_DASHBOARD_URL=https://dashboard.your-domain.com

# Option 2: Subdomain per demo
# NEXT_PUBLIC_BASE_DOMAIN=demos.your-domain.com

# Leave both empty for local development defaults:
# - Landing: http://localhost:3002
# - Dashboard: http://localhost:3003?namespace={demo-name}
