FROM golang:1.24.13-bookworm AS builder
ARG TARGETOS
ARG TARGETARCH
ARG VERSION=dev
ARG GIT_COMMIT=unknown

WORKDIR /workspace
ENV GOTOOLCHAIN=auto
COPY go.mod go.mod
COPY go.sum go.sum
RUN go mod download

COPY cmd/query-engine/ cmd/query-engine/
COPY api/ api/
COPY internal/ internal/

RUN CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH} GOTOOLCHAIN=auto go build \
    -ldflags "-X main.Version=${VERSION} -X main.GitCommit=${GIT_COMMIT}" \
    -a -o query-engine cmd/query-engine/main.go

FROM gcr.io/distroless/static:nonroot
WORKDIR /
COPY --from=builder /workspace/query-engine .
USER 65532:65532

ENTRYPOINT ["/query-engine"]
